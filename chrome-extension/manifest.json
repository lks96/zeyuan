{
  "manifest_version": 3,
  "name": "Temu Tools 数据同步助手",
  "description": "捕获 Temu 卖家中心接口数据，并同步到 temu-tools 商品采集和发货提取接口。",
  "version": "0.1.0",
  "key": "",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Temu Tools 同步",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.temu.com/*",
        "https://*.kuajingmaihuo.com/*"
      ],
      "js": ["content-script.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": [
        "https://*.temu.com/*",
        "https://*.kuajingmaihuo.com/*"
      ]
    }
  ],
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://*.temu.com/*",
    "https://*.kuajingmaihuo.com/*",
    "http://localhost:8080/*",
    "http://127.0.0.1:8080/*",
    "http://*/*",
    "https://*/*"
  ]
}
